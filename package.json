{
  "name": "kommerce-api",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "start": "node build/server.js",
    "build": "tsup --config tsup.config.ts && prisma generate && node scripts/prepare-runtime-deps.cjs && node -e \"const fs=require('fs');fs.writeFileSync('build/package.json', JSON.stringify({type:'module'}, null, 2));\"",
    "seed": "pnpm exec prisma db seed",
    "seed:base": "pnpm exec prisma migrate deploy --schema prisma/schema.prisma && pnpm exec tsx src/scripts/seed-base-data.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@fastify/cookie": "11.0.2",
    "@fastify/cors": "11.2.0",
    "@fastify/jwt": "10.0.0",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.5",
    "@libsql/client": "0.17.0",
    "@prisma/adapter-libsql": "7.4.2",
    "bcryptjs": "3.0.3",
    "dotenv": "17.2.3",
    "fastify": "5.6.2",
    "puppeteer": "24.38.0",
    "qrcode": "1.5.4",
    "uuidv7": "1.1.0",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@prisma/client": "7.4.0",
    "@types/node": "25.0.1",
    "@types/qrcode": "1.5.6",
    "@vitest/coverage-v8": "4.0.15",
    "@vitest/ui": "4.0.15",
    "prisma": "7.4.0",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "4.0.15"
  },
  "optionalDependencies": {
    "@libsql/win32-x64-msvc": "0.5.22"
  }
}
